# ========================================
# Google Gemini API
# ========================================
GEMINI_API_KEY=your-gemini-api-key-here

# ========================================
# Google Cloud Services
# ========================================
# Google Places API
GOOGLE_PLACES_API_KEY=your-google-places-api-key-here

# Google Cloud Storage (プロンプト保存用)
PROMPTS_BUCKET_NAME=your-gcs-bucket-name

# ========================================
# External APIs
# ========================================
# HotPepper API
HOTPEPPER_API_KEY=your-hotpepper-api-key-here

# TripAdvisor API
TRIPADVISOR_API_KEY=your-tripadvisor-api-key-here

# ========================================
# Long-term Memory (Supabase)
# ========================================
# SupabaseプロジェクトURL
# 例: https://bisguyfngvlpcgagrdmr.supabase.co
SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co

# Supabase Anon Public Key
# Supabase Dashboard → Settings → API → Project API keys → anon public
# 例: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_KEY=your-supabase-anon-key-here

# ========================================
# Application Settings
# ========================================
# Flask環境
FLASK_ENV=production

# ポート（Cloud Runでは$PORTが自動設定される）
PORT=8080
