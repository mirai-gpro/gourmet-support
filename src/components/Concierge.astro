---
// Concierge.astro - グルメコンシェルジュモード
export interface Props {
  apiBaseUrl?: string;
}

const { apiBaseUrl = '' } = Astro.props;
---

<div class="concierge-container" data-api-base={apiBaseUrl} data-mode="concierge">
  <!-- アバター表示エリア -->
  <div class="avatar-area">
    <div class="avatar-image" id="avatarImage">
      <!-- 将来的にアニメーションアバターを配置 -->
      <img src="/avatar-placeholder.png" alt="Concierge Avatar" />
    </div>
    <div class="avatar-status" id="avatarStatus">
      <span class="status-indicator"></span>
      <span class="status-text">待機中</span>
    </div>
  </div>

  <div class="chat-header">
    <h2>🤵 グルメコンシェルジュ</h2>
    <p>あなたの食体験をサポートします</p>
  </div>

  <div class="voice-status stopped" id="voiceStatus">
    &#127908; 音声認識: 停止中
  </div>

  <div class="chat-area" id="chatArea">
    <!-- メッセージはJSで動的に追加 -->
  </div>

  <div class="input-area">
    <div class="input-group">
      <input
        type="text"
        id="userInput"
        placeholder="どのようなシーンでしょうか？"
        disabled
      />
      <button class="btn btn-icon btn-mic" id="micBtn" title="音声入力" disabled>
        &#127908;
      </button>
      <button class="btn btn-icon btn-speaker" id="speakerBtn" title="音声読み上げON" disabled>
        &#128266;
      </button>
      <button class="btn" id="sendBtn" disabled>
        送信
      </button>
    </div>
    <div class="input-actions">
      <button class="btn btn-reservation" id="reservationBtn" disabled>
        &#128222; 予約依頼する
      </button>
    </div>
  </div>
</div>

<style>
  .concierge-container {
    background: linear-gradient(135deg, #fdfcfb 0%, #f7f6f4 100%);
    border-radius: 20px;
    box-shadow: 0 25px 70px rgba(0, 0, 0, 0.2);
    width: 100%;
    max-width: 900px;
    max-height: 700px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    margin: 0 auto;
    border: 2px solid #e5ddd5;
  }

  /* アバター表示エリア */
  .avatar-area {
    background: linear-gradient(135deg, #c9a869 0%, #b8976f 100%);
    padding: 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    border-bottom: 3px solid #a68759;
  }

  .avatar-image {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background: white;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
    overflow: hidden;
  }

  .avatar-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .avatar-status {
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(255, 255, 255, 0.9);
    padding: 6px 16px;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 600;
    color: #5d4e37;
  }

  .status-indicator {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #10b981;
    animation: pulse-indicator 2s infinite;
  }

  @keyframes pulse-indicator {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.7; transform: scale(1.1); }
  }

  .chat-header {
    background: linear-gradient(135deg, #c9a869 0%, #8b7355 100%);
    color: white;
    padding: 20px;
    text-align: center;
  }

  .chat-header h2 {
    font-size: 22px;
    font-weight: 700;
    margin: 0 0 4px 0;
    letter-spacing: 0.5px;
  }

  .chat-header p {
    font-size: 14px;
    opacity: 0.95;
    margin: 0;
  }

  .voice-status {
    padding: 10px 15px;
    text-align: center;
    font-size: 12px;
    border-bottom: 1px solid #e0e0e0;
    font-weight: 500;
  }

  .voice-status.listening {
    background: #e8f5e9;
    color: #2e7d32;
    animation: pulse 2s infinite;
  }

  .voice-status.stopped {
    background: #fff8f1;
    color: #c67c4e;
  }

  .voice-status.speaking {
    background: #fef3c7;
    color: #b45309;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.8; }
  }

  .chat-area {
    flex: 1;
    overflow-y: auto;
    padding: 20px;
    background: #fdfcfb;
    min-height: 300px;
  }

  .message {
    margin-bottom: 16px;
    display: flex;
    gap: 10px;
  }

  .message.assistant {
    flex-direction: row;
  }

  .message.user {
    flex-direction: row-reverse;
  }

  .message.system {
    justify-content: center;
  }

  .message-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    flex-shrink: 0;
  }

  .message.assistant .message-avatar {
    background: linear-gradient(135deg, #c9a869 0%, #8b7355 100%);
    color: white;
    box-shadow: 0 4px 10px rgba(201, 168, 105, 0.3);
  }

  .message.user .message-avatar {
    background: #f3f1ee;
    color: #8b7355;
  }

  .message.system .message-avatar {
    background: #fff3e0;
    color: #f57c00;
  }

  .message-content {
    max-width: 70%;
    padding: 12px 16px;
    border-radius: 14px;
    line-height: 1.6;
    font-size: 14px;
    white-space: pre-wrap;
  }

  .message.assistant .message-content {
    background: white;
    border: 2px solid #e5ddd5;
    color: #2d2416;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  }

  .message.user .message-content {
    background: linear-gradient(135deg, #c9a869 0%, #b8976f 100%);
    color: white;
  }

  .message.system .message-content {
    background: #fff8f1;
    color: #c67c4e;
    font-size: 12px;
  }

  .summary-box {
    margin-top: 10px;
    padding: 10px;
    background: #fef3c7;
    border-left: 4px solid #f59e0b;
    border-radius: 8px;
    font-size: 13px;
    color: #92400e;
  }

  .summary-box strong {
    display: block;
    margin-bottom: 6px;
    color: #78350f;
  }

  .final-summary {
    margin: 16px 0;
    padding: 16px;
    background: white;
    border: 2px solid #c9a869;
    border-radius: 12px;
  }

  .final-summary h3 {
    color: #8b7355;
    margin: 0 0 10px 0;
    font-size: 16px;
  }

  .final-summary-content {
    white-space: pre-wrap;
    line-height: 1.7;
    color: #2d2416;
    font-size: 13px;
  }

  .input-area {
    padding: 16px;
    background: linear-gradient(180deg, #ffffff 0%, #fdfcfb 100%);
    border-top: 2px solid #e5ddd5;
  }

  .input-group {
    display: flex;
    gap: 10px;
    align-items: center;
    margin-bottom: 10px;
  }

  #userInput {
    flex: 1;
    padding: 12px 16px;
    border: 2px solid #e5ddd5;
    border-radius: 25px;
    font-size: 14px;
    outline: none;
    transition: all 0.3s;
    background: white;
  }

  #userInput:focus {
    border-color: #c9a869;
    box-shadow: 0 0 0 3px rgba(201, 168, 105, 0.1);
  }

  .btn {
    padding: 12px 18px;
    background: linear-gradient(135deg, #c9a869 0%, #8b7355 100%);
    color: white;
    border: none;
    border-radius: 25px;
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s;
    box-shadow: 0 4px 12px rgba(201, 168, 105, 0.3);
  }

  .btn:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(201, 168, 105, 0.4);
  }

  .btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .btn-secondary {
    background: #f3f1ee;
    color: #8b7355;
    font-size: 12px;
    padding: 8px 12px;
  }

  .btn-secondary:hover:not(:disabled) {
    background: #e5ddd5;
    box-shadow: none;
    transform: none;
  }

  .btn-reservation {
    background: linear-gradient(135deg, #d4a574 0%, #b8976f 100%);
    color: white;
    font-size: 13px;
    padding: 10px 16px;
    font-weight: 700;
    box-shadow: 0 4px 12px rgba(212, 165, 116, 0.3);
  }

  .btn-reservation:hover:not(:disabled) {
    box-shadow: 0 6px 16px rgba(212, 165, 116, 0.4);
    transform: translateY(-1px);
  }

  .btn-reservation:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .btn-icon {
    padding: 10px;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .btn-mic {
    background: #10b981;
  }

  .btn-mic:hover:not(:disabled) {
    box-shadow: 0 4px 12px rgba(16, 185, 129, 0.4);
  }

  .btn-mic.recording {
    background: #ef4444;
    animation: pulse-btn 1.5s infinite;
  }

  @keyframes pulse-btn {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.7; }
  }

  .btn-speaker {
    background: #f59e0b;
  }

  .btn-speaker:hover:not(:disabled) {
    box-shadow: 0 4px 12px rgba(245, 158, 11, 0.4);
  }

  .btn-speaker.disabled {
    background: #9ca3af;
  }

  .input-actions {
    display: flex;
    justify-content: flex-end;
  }

  .loading {
    display: inline-block;
    width: 20px;
    height: 20px;
    border: 3px solid #e5ddd5;
    border-radius: 50%;
    border-top-color: #c9a869;
    animation: spin 1s ease-in-out infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .error-message {
    background: #fee2e2;
    color: #b91c1c;
    padding: 10px;
    border-radius: 8px;
    margin: 10px 0;
    font-size: 13px;
    text-align: center;
  }

  /* クリックプロンプト */
  .click-prompt {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: rgba(45, 36, 22, 0.9);
    color: white;
    padding: 20px;
    border-radius: 12px;
    text-align: center;
    z-index: 100;
    cursor: pointer;
  }

  .click-prompt p {
    margin: 5px 0;
  }
</style>

<!-- Socket.IO クライアントライブラリ（WebSocket Streaming STT用） -->
<script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>

<script>
  // グルメコンシェルジュ機能（GourmetChat.astroと同じロジック）
  document.addEventListener('DOMContentLoaded', () => {
    const container = document.querySelector('.concierge-container') as HTMLElement;
    if (!container) return;

    const apiBase = container.dataset.apiBase || '';
    const mode = container.dataset.mode || 'concierge'; // コンシェルジュモード

    // DOM要素
    const chatArea = document.getElementById('chatArea')!;
    const userInput = document.getElementById('userInput') as HTMLInputElement;
    const sendBtn = document.getElementById('sendBtn') as HTMLButtonElement;
    const micBtn = document.getElementById('micBtn') as HTMLButtonElement;
    const speakerBtn = document.getElementById('speakerBtn') as HTMLButtonElement;
    const reservationBtn = document.getElementById('reservationBtn') as HTMLButtonElement;
    const voiceStatus = document.getElementById('voiceStatus')!;
    const avatarStatus = document.getElementById('avatarStatus')!;

    console.log('[Concierge] モード:', mode);

    // 状態（GourmetChatと同じ）
    let sessionId: string | null = null;
    let isProcessing = false;
    let currentStage = 'conversation';
    let isRecording = false;
    let mediaRecorder: MediaRecorder | null = null;
    let audioChunks: Blob[] = [];
    let recordingTimer: number | null = null;
    const MAX_RECORDING_TIME = 55000;
    let isTTSEnabled = true;
    let currentAudio: HTMLAudioElement | null = null;
    let isUserInteracted = false;
    let currentShops: any[] = [];
    let isFromVoiceInput = false;
    let currentLanguage: string = 'ja';

    let preGeneratedAcks: Map<string, string> = new Map();

    let audioContext: AudioContext | null = null;
    let analyser: AnalyserNode | null = null;
    let silenceTimer: number | null = null;
    let vadCheckInterval: number | null = null;
    let hasSpoken = false;
    let recordingStartTime = 0;
    const SILENCE_THRESHOLD = 35;
    const SILENCE_DURATION = 2000;
    const MIN_RECORDING_TIME = 3000;

    let socket: any = null;
    let audioWorkletNode: AudioWorkletNode | null = null;
    let streamingTranscript = '';
    let isStreamingSTT = false;

    // アバターステータス更新
    function updateAvatarStatus(status: string, text: string) {
      if (avatarStatus) {
        const indicator = avatarStatus.querySelector('.status-indicator') as HTMLElement;
        const statusText = avatarStatus.querySelector('.status-text') as HTMLElement;

        if (indicator && statusText) {
          statusText.textContent = text;

          // ステータスに応じて色を変更
          if (status === 'listening') {
            indicator.style.background = '#10b981';
          } else if (status === 'speaking') {
            indicator.style.background = '#f59e0b';
          } else if (status === 'thinking') {
            indicator.style.background = '#3b82f6';
          } else {
            indicator.style.background = '#6b7280';
          }
        }
      }
    }

    // NOTE: 以下、GourmetChat.astroと同じ関数群をそのまま使用
    // （enableAudioPlayback, showClickPrompt, stopCurrentAudio, stripMarkdown,
    //   speakTextGCP, stopVAD, autoStopRecording, toggleRecording, など）

    // 簡略化のため、主要な初期化ロジックのみ記載
    async function initialize() {
      currentLanguage = detectLanguage();
      console.log('[Concierge] 言語検出:', currentLanguage);

      try {
        const response = await fetch(`${apiBase}/api/session/start`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            user_info: {},
            language: currentLanguage,
            mode: mode // コンシェルジュモードを指定
          })
        });

        const data = await response.json();
        sessionId = data.session_id;

        // コンシェルジュ向け初期メッセージ
        const conciergeGreeting = "いらっしゃいませ。グルメコンシェルジュです。今日はどのようなシーンでしょうか？接待、デート、女子会など、お気軽にお聞かせください。";
        addMessage('assistant', conciergeGreeting);
        updateAvatarStatus('ready', '待機中');

        // 事前生成音声
        const ackTexts = [
          "確認しますので、少々お待ちください。",
          "お調べします。",
          "かしこまりました。",
          "はい、承知しました。",
          "ご希望に合うお店を5件ご紹介します。",
          "ご希望に合うお店を3件ご紹介します。",
          "ご希望に合うお店をご紹介します。"
        ];

        const ackPromises = ackTexts.map(async (text) => {
          try {
            const ackResponse = await fetch(`${apiBase}/api/tts/synthesize`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                text: text,
                language_code: 'ja-JP',
                voice_name: 'ja-JP-Chirp3-HD-Leda'
              })
            });
            const ackData = await ackResponse.json();
            if (ackData.success && ackData.audio) {
              preGeneratedAcks.set(text, ackData.audio);
              console.log(`[初期化] 事前生成完了: "${text}"`);
            }
          } catch (error) {
            console.error(`[初期化] 事前生成失敗: "${text}"`, error);
          }
        });

        await Promise.all([
          speakTextGCP(conciergeGreeting),
          ...ackPromises
        ]);

        userInput.disabled = false;
        sendBtn.disabled = false;
        micBtn.disabled = false;
        speakerBtn.disabled = false;
        userInput.focus();

        console.log(`[Concierge] 初期化完了 (事前生成音声: ${preGeneratedAcks.size}件)`);

        // WebSocket STT初期化
        initializeWebSocketSTT();

      } catch (error) {
        console.error('[Concierge] 初期化エラー:', error);
        showError('初期化に失敗しました。ページを再読み込みしてください。');
      }
    }

    // 言語検出
    function detectLanguage(): string {
      const browserLang = navigator.language || (navigator as any).userLanguage;
      if (browserLang.startsWith('ja')) return 'ja';
      if (browserLang.startsWith('en')) return 'en';
      if (browserLang.startsWith('zh')) return 'zh';
      if (browserLang.startsWith('ko')) return 'ko';
      return 'ja';
    }

    // メッセージ追加
    function addMessage(role: string, content: string, summary: string | null = null) {
      const messageDiv = document.createElement('div');
      messageDiv.className = `message ${role}`;

      const avatar = document.createElement('div');
      avatar.className = 'message-avatar';
      avatar.innerHTML = role === 'assistant' ? '🤵' : role === 'user' ? '👤' : '⚠';

      const contentDiv = document.createElement('div');
      contentDiv.className = 'message-content';
      contentDiv.textContent = content;

      messageDiv.appendChild(avatar);

      const wrapper = document.createElement('div');
      wrapper.appendChild(contentDiv);

      if (summary) {
        const summaryDiv = document.createElement('div');
        summaryDiv.className = 'summary-box';
        summaryDiv.innerHTML = `<strong>📝 内容確認</strong>${summary}`;
        wrapper.appendChild(summaryDiv);
      }

      messageDiv.appendChild(wrapper);
      chatArea.appendChild(messageDiv);
      chatArea.scrollTop = chatArea.scrollHeight;
    }

    // エラー表示
    function showError(message: string) {
      const errorDiv = document.createElement('div');
      errorDiv.className = 'error-message';
      errorDiv.textContent = message;
      chatArea.appendChild(errorDiv);
      chatArea.scrollTop = chatArea.scrollHeight;
    }

    // NOTE: 残りの関数（speakTextGCP, toggleRecording, sendMessage など）は
    // GourmetChat.astroと同じものを使用するため省略
    // 実際の実装では全ての関数をコピーする必要があります

    // 初期化実行
    initialize();
  });
</script>
