<div class="gourmet-chat-container" data-api-base={apiBaseUrl}>
  <div class="chat-header-controls">
    <div class="mode-toggle-wrapper">
      <label class="switch-label">
        <span class="label-text">Concierge</span>
        <div class="toggle-switch">
          <input type="checkbox" id="modeSwitch">
          <span class="slider"></span>
        </div>
      </label>
    </div>

    <div class="language-selector">
       <select id="languageSelect" class="language-dropdown">
         <option value="ja">日本語</option>
         <option value="en">English</option>
         </select>
    </div>
  </div>

  <div class="avatar-stage" id="avatarStage">
    <div class="avatar-container">
      <img id="avatarImage" src="/images/avatar-robot.png" alt="AI Avatar" class="avatar-img" />
    </div>
  </div>

  <div class="voice-status stopped" id="voiceStatus">🎤 Ready</div>
  
  <div class="chat-area" id="chatArea"></div>

  <div class="input-area">
    </div>
  
  </div>

<style>
/* ★ CSSの大幅更新 */

/* コンテナをFlexboxで縦積みにし、画面高さを確保 */
.gourmet-chat-container {
  background: white;
  border-radius: 16px;
  box-shadow: 0 20px 60px rgba(0,0,0,0.15);
  width: 100%;
  max-width: 800px;
  height: 95vh;         /* ★画面の高さを確保 */
  max-height: 800px;
  display: flex;
  flex-direction: column; /* ★縦並び */
  overflow: hidden;
  margin: 0 auto;
  position: relative;
}

/* ヘッダー */
.chat-header-controls {
  flex-shrink: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 16px;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  transition: background 0.5s ease;
}
:global(.gourmet-chat-container.mode-concierge .chat-header-controls) {
  background: linear-gradient(135deg, #b45309 0%, #d97706 100%);
}

/* アバターステージ */
.avatar-stage {
  flex-shrink: 0;
  height: 180px;
  background: #f0f2f5;
  display: flex;
  justify-content: center;
  align-items: flex-end;
  border-bottom: 1px solid #e0e0e0;
  transition: background 0.5s ease;
}
:global(.gourmet-chat-container.mode-concierge .avatar-stage) {
  background: linear-gradient(to bottom, #fff8e1, #ffecb3);
}
.avatar-container {
  width: 140px;
  height: 140px;
  transition: transform 0.3s ease;
}
.avatar-img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  filter: drop-shadow(0 4px 6px rgba(0,0,0,0.2));
  transition: opacity 0.2s;
}
/* 喋っている時のアニメーション */
.avatar-container.speaking .avatar-img {
  animation: breathe 1s infinite alternate ease-in-out;
}
@keyframes breathe {
  0% { transform: scale(1); }
  100% { transform: scale(1.05) translateY(-2px); }
}

/* チャットエリア (ここだけスクロール) */
.chat-area {
  flex: 1;           /* ★残りの空間を全て使う */
  overflow-y: auto;  /* ★スクロール有効 */
  padding: 20px;
  background: #f7f9fc;
}

/* 入力エリア (固定) */
.input-area {
  flex-shrink: 0;
  padding: 16px;
  background: white;
  border-top: 1px solid #e5e7eb;
}

/* スイッチのスタイル */
.switch-label { display: flex; align-items: center; gap: 8px; cursor: pointer; }
.label-text { color: white; font-size: 12px; font-weight: 600; }
.toggle-switch { position: relative; width: 44px; height: 24px; }
.toggle-switch input { opacity: 0; width: 0; height: 0; }
.slider { position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: rgba(0,0,0,0.3); transition: .4s; border-radius: 24px; border: 1px solid rgba(255,255,255,0.4); }
.slider:before { position: absolute; content: ""; height: 18px; width: 18px; left: 2px; bottom: 2px; background-color: white; transition: .4s; border-radius: 50%; }
input:checked + .slider { background-color: #f59e0b; }
input:checked + .slider:before { transform: translateX(20px); }

/* モバイル調整 */
@media (max-height: 700px) {
  .avatar-stage { height: 120px; }
  .avatar-container { width: 90px; height: 90px; }
}
</style>